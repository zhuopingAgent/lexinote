{
  "mcpServers": {
    "next-devtools-mcp": {
      "command": "npx",
      "args": ["-y", "next-devtools-mcp@latest"]
    },
    "@playwright/mcp": {
      "command": "npx",
      "args": ["-y", "@playwright/mcp@latest"]
    },
    "postgres": {
      "command": "node",
      "args": ["scripts/run-postgres-mcp.mjs"]
    }
  }
}
